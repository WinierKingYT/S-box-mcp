@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<root class="prompt @(IsActive ? "active" : "")">
	<div class="key">E</div>
	<div class="action">@PromptText</div>
</root>

<style>
.prompt {
	position: absolute;
	left: 50%;
	top: 55%;
	transform: translate(-50%, -50%);
	flex-direction: row;
	align-items: center;
	background-color: rgba(20, 20, 20, 0.85);
	border-radius: 8px;
	padding: 8px 16px;
	border: 2px solid rgba(100, 200, 255, 0.3);
	box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.5);
	opacity: 0;
	transition: all 0.2s ease-in-out;
	pointer-events: none;
}

.prompt.active {
	opacity: 1;
	transform: translate(-50%, -60px);
}

.key {
	color: white;
	font-size: 18px;
	font-weight: bold;
	background-color: rgb(38, 128, 255);
	border-radius: 4px;
	padding: 2px 8px;
	margin-right: 10px;
}

.action {
	color: white;
	font-size: 16px;
	font-weight: 500;
}
</style>

@code {
	[Property] public bool IsActive { get; set; }
	[Property] public string PromptText { get; set; } = "ARABAYI SÜR";
}
